# Only needed for the LLM bits (the explain toggle in the app, and augment.py).
# The classifier itself runs fine without any of this.
OPENROUTER_API_KEY=your_openrouter_key

# any OpenRouter model id works - swap these if you want
EXPLAIN_MODEL=google/gemini-3.5-flash
SYNTHESIS_MODEL=openai/gpt-4o-mini
